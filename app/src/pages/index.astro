---
import { siteMeta } from '../content';
import AllProjectsSection from '../components/AllProjectsSection.astro';
import BodySection from '../components/BodySection.astro';
import BrainSection from '../components/BrainSection.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import MorphBar from '../components/MorphBar.astro';
import Nav from '../components/Nav.astro';
import RoomsSection from '../components/RoomsSection.astro';
import Base from '../layouts/Base.astro';
---

<Base title={siteMeta.title} description={siteMeta.description}>
  <Nav />

  <main id="main">
    <Hero />
    <MorphBar from="hero" to="body" fromVariant="body" toVariant="body" />
    <BodySection />
    <MorphBar from="body (mechanical joint)" to="brain (neural node)" fromVariant="body" toVariant="brain" />
    <BrainSection />
    <MorphBar from="brain (neural node)" to="rooms (network)" fromVariant="brain" toVariant="rooms" fromColor="#0F1620" />
    <RoomsSection />
    <MorphBar from="rooms" to="the whole map" fromVariant="rooms" toVariant="body" />
    <AllProjectsSection />
    <Contact />
  </main>
  <Footer />
</Base>
