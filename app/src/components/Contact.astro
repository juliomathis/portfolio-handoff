---
import { contactHeading, contactLinks } from '../content';
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div>
    <div class="mono contact-kicker">// 04 — let's work</div>
    <h2 id="contact-heading">
      {contactHeading.lead} <span class="c1">{contactHeading.body}</span>,<br />
      {contactHeading.mid} <span class="c2">{contactHeading.brain}</span>,<br />
      {contactHeading.tailLead} <span class="c3">{contactHeading.rooms}</span>.
    </h2>
  </div>

  <div class="contact-info">
    {
      contactLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))
    }
  </div>
</section>
