---
import type { SectionKey } from '../lib/types';

interface Props {
  size?: number;
  variant?: SectionKey;
  stroke?: string;
  fill?: string;
  class?: string;
}

const {
  size = 80,
  variant = 'body',
  stroke = 'var(--ink)',
  fill = 'var(--paper)',
  class: className = '',
}: Props = Astro.props;

const roomAngles = [0, 60, 120, 180, 240, 300];
---

<svg
  class={`motif-joint ${className}`}
  width={size}
  height={size}
  viewBox="0 0 80 80"
  aria-hidden="true"
  focusable="false"
>
  {
    variant === 'body' && (
      <>
        <circle cx="40" cy="40" r="32" fill="none" stroke={stroke} stroke-width="1.5" />
        <circle cx="40" cy="40" r="22" fill={fill} stroke={stroke} stroke-width="1.5" />
        <line x1="40" y1="8" x2="40" y2="72" stroke={stroke} stroke-width="1" stroke-dasharray="2 3" />
        <line x1="8" y1="40" x2="72" y2="40" stroke={stroke} stroke-width="1" stroke-dasharray="2 3" />
        <circle cx="40" cy="40" r="5" fill={stroke} />
      </>
    )
  }

  {
    variant === 'brain' && (
      <>
        {
          [
            [12, 18],
            [68, 22],
            [14, 62],
            [66, 60],
            [40, 10],
            [40, 70],
          ].map(([x, y]) => (
            <g>
              <line x1="40" y1="40" x2={x} y2={y} stroke={stroke} stroke-width="1" opacity="0.7" />
              <circle cx={x} cy={y} r="3" fill={stroke} />
            </g>
          ))
        }
        <circle cx="40" cy="40" r="10" fill={fill} stroke={stroke} stroke-width="1.5" />
        <circle cx="40" cy="40" r="3" fill={stroke} />
      </>
    )
  }

  {
    variant === 'rooms' && (
      <>
        <circle cx="40" cy="40" r="18" fill="none" stroke={stroke} stroke-width="1.5" stroke-dasharray="3 2" />
        {
          roomAngles.map((angle) => {
            const radius = 30;
            const x = 40 + radius * Math.cos((angle * Math.PI) / 180);
            const y = 40 + radius * Math.sin((angle * Math.PI) / 180);

            return <circle cx={x} cy={y} r="5" fill={fill} stroke={stroke} stroke-width="1.5" />;
          })
        }
        <circle cx="40" cy="40" r="3" fill={stroke} />
      </>
    )
  }
</svg>
